{
  "name": "@satcomx00-x00/sonatype-repository-firewall-mcp",
  "version": "0.0.1",
  "description": "A state-of-the-art Model Context Protocol (MCP) server for the Sonatype Repository Firewall / IQ Server REST API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sonatype-firewall-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose"
  },
  "keywords": [
    "mcp",
    "sonatype",
    "nexus",
    "firewall",
    "security",
    "iq",
    "openapi"
  ],
  "author": "",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Satcomx00-x00/Sonatype-Repository-Firewall-MCP.git"
  },
  "bugs": {
    "url": "https://github.com/Satcomx00-x00/Sonatype-Repository-Firewall-MCP/issues"
  },
  "homepage": "https://github.com/Satcomx00-x00/Sonatype-Repository-Firewall-MCP#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "fastmcp": "^3.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.11",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
