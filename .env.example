# ─── Sonatype IQ Server ─────────────────────────────────────────────────────
# Base URL of your Sonatype IQ Server instance
IQ_SERVER_URL=http://localhost:8070

# IQ Server credentials (Basic Auth)
IQ_SERVER_USERNAME=admin
IQ_SERVER_PASSWORD=admin123

# ─── Nexus Repository Manager (optional) ────────────────────────────────────
# When set, Nexus Repository Manager IQ/Firewall integration tools are enabled.
# NEXUS_URL=http://localhost:8081
# NEXUS_USERNAME=admin
# NEXUS_PASSWORD=admin123

# ─── HTTP Client ─────────────────────────────────────────────────────────────
# Request timeout in milliseconds (default: 30000)
HTTP_TIMEOUT_MS=30000

# Number of retries on transient errors (default: 3, max: 5)
HTTP_RETRY_COUNT=3

# Base delay between retries in ms — doubles each attempt (default: 500)
HTTP_RETRY_DELAY_MS=500

# ─── MCP Server ──────────────────────────────────────────────────────────────
# Transport type: stdio (default, for MCP clients) | httpStream (for HTTP)
MCP_TRANSPORT=stdio

# HTTP port when MCP_TRANSPORT=httpStream (default: 3000)
MCP_HTTP_PORT=3000

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info
